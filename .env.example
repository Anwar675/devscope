# =========================
# Devscope environment file
# =========================
# Copy file nay thanh `.env` khi chay local.
# Tren Vercel/Railway, nhap cac key nay vao phan Environment Variables.
# Khong commit file `.env` that vi co secret.

# -------------------------
# Database
# -------------------------
# Connection string PostgreSQL dung cho Drizzle, Better Auth, metrics va load test history.
# Vi du: postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require
DATABASE_URL=""

# -------------------------
# Better Auth
# -------------------------
# Secret dung de ky session/cookie cua Better Auth. Nen tao chuoi random dai.
# Vi du tao nhanh: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# URL public cua frontend dang chay Better Auth.
# Local: http://localhost:3000
# Production: https://your-vercel-app.vercel.app
BETTER_AUTH_URL="http://localhost:3000"

# -------------------------
# Backend server
# -------------------------
# Port local cho Express backend. Railway tu inject PORT, nen production thuong khong can set.
PORT="3001"

# Port fallback neu muon dung ten rieng khi chay local backend.
BACKEND_PORT="3001"

# Origin frontend duoc backend cho phep goi API voi cookie/credentials.
# Local: http://localhost:3000
# Production: https://your-vercel-app.vercel.app
FRONTEND_URL="http://localhost:3000"

# -------------------------
# Frontend -> Backend
# -------------------------
# URL public cua Railway backend de cac Next.js API route proxy request sang Express backend.
# Local: http://localhost:3001
# Production: https://your-railway-backend.up.railway.app
NEXT_PUBLIC_API_URL="http://localhost:3001"

# URL public cua backend cho realtime loadtest WebSocket.
# Neu de giong NEXT_PUBLIC_API_URL, frontend se doi http -> ws va https -> wss.
NEXT_PUBLIC_LOADTEST_WS_URL="http://localhost:3001"

# -------------------------
# OpenAI
# -------------------------
# API key dung cho AI analysis va architecture recommendation.
OPENAI_API_KEY=""

# Alias cu neu muon dung thay OPENAI_API_KEY. Code se uu tien OPENAI_API_KEY truoc.
OPENAI_KEY=""

# Model OpenAI dung khi tao analysis. Neu bo trong, code fallback ve gpt-4.1-mini.
OPENAI_MODEL="gpt-4.1-mini"

# -------------------------
# OAuth providers
# -------------------------
# GitHub OAuth app credentials dung cho dang nhap GitHub.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth app credentials dung cho dang nhap Google.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -------------------------
# Load test infrastructure agent
# -------------------------
# Shared token cho endpoint post metrics infrastructure:
# /api/loadtest/[id]/infrastructure
# Chi can neu ban co agent rieng day CPU/RAM/container/pod metrics ve app.
LOADTEST_AGENT_TOKEN=""
